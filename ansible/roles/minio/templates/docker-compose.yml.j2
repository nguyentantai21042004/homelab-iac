version: "3.8"

networks:
  storage-net:
    driver: bridge

services:
  minio:
    image: quay.io/minio/minio:RELEASE.2024-03-30T09-41-56Z
    container_name: minio
    restart: always
    networks:
      - storage-net
    ports:
      - "9000:9000"
      - "9001:9001"
    environment:
      MINIO_ROOT_USER: ${MINIO_ROOT_USER}
      MINIO_ROOT_PASSWORD: ${MINIO_ROOT_PASSWORD}
    volumes:
      - {{ storage_data_path }}/minio:/data
    command: server /data --console-address ":9001"
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:9000/minio/health/live"]
      interval: 30s
      timeout: 20s
      retries: 3

  createbuckets:
    image: minio/mc:RELEASE.2024-02-24T01-33-20Z
    container_name: minio-mc
    networks:
      - storage-net
    depends_on:
      minio:
        condition: service_healthy
    entrypoint: >
      /bin/sh -c "
      /usr/bin/mc alias set myminio http://minio:9000 ${MINIO_ROOT_USER} ${MINIO_ROOT_PASSWORD};
      /usr/bin/mc mb --ignore-existing myminio/harbor-registry;
      exit 0;
      "
