# Harbor configuration
# Generated by Ansible — do not edit manually
# Reference: https://goharbor.io/docs/latest/install-config/configure-yml-file/

hostname: {{ ansible_host }}

# HTTP only — TLS is terminated by the external Traefik API Gateway
http:
  port: {{ harbor_http_port }}

# External URL used by Docker clients and Harbor UI redirects
external_url: {{ harbor_external_url }}

harbor_admin_password: {{ harbor_admin_password }}

# Internal Harbor database (postgres inside docker-compose)
database:
  password: {{ harbor_admin_password }}
  max_idle_conns: 10
  max_open_conns: 100
  conn_max_lifetime: 5m
  conn_max_idle_time: 0

# Use MinIO S3 as image storage backend
storage_service:
  ca_bundle:
  s3:
    accesskey: {{ harbor_s3_accesskey }}
    secretkey: {{ harbor_s3_secretkey }}
    region: {{ harbor_s3_region }}
    regionendpoint: {{ harbor_s3_regionendpoint }}
    bucket: {{ harbor_s3_bucket }}
    secure: false
    skipverify: true
    forcepathstyle: true
    disableredirect: true

jobservice:
  max_job_workers: 10
  job_loggers:
    - STD_OUTPUT
    - FILE
  logger_sweeper_duration: 1

notification:
  webhook_job_max_retry: 3
  webhook_job_http_client_timeout: 3

log:
  level: info
  local:
    rotate_count: 50
    rotate_size: 200m
    location: /var/log/harbor

data_volume: {{ harbor_install_path }}/data

trivy:
  ignore_unfixed: false
  skip_update: false
  offline_scan: false
  security_check: vuln
  insecure: false

proxy:
  http_proxy:
  https_proxy:
  no_proxy:
  components:
    - core
    - jobservice
    - trivy

upload_purging:
  enabled: true
  age: 168h
  interval: 24h
  dryrun: false

cache:
  enabled: false
  expire_hours: 24
